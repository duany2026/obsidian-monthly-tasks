# ============================================
# obsidian-monthly-tasks .gitignore
# ============================================

# 构建输出（由 esbuild 生成）
main.js
*.js.map

# 依赖目录
node_modules/

# Obsidian 插件数据
data.json

# 编辑器配置
.vscode/
.idea/
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 日志文件
*.log
npm-debug.log*

# 工作区临时文件
.workbuddy/

# 打包分发产物（不需要纳入版本管理）
*.zip
